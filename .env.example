# Discord Bot Token (from https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Supabase Credentials (from https://supabase.com/dashboard/project/_/settings/api)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_anon_or_service_role_key_here

# Webhook Cache Sync (HMAC-signed dashboard -> bot cache invalidation)
# Strong random secret shared with the dashboard. Empty -> webhook server disabled.
WEBHOOK_SECRET=
# Bind address for the webhook aiohttp server. Use 0.0.0.0 on Pterodactyl; 127.0.0.1 locally.
WEBHOOK_HOST=127.0.0.1
# Port for the webhook server. Falls back to 8080 if absent or invalid.
WEBHOOK_PORT=8080

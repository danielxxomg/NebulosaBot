# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Discord OAuth2
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Discord Bot (for server-side guild info lookups)
DISCORD_BOT_TOKEN=

# Webhook Cache Sync (HMAC-signed dashboard -> bot cache invalidation)
# Base URL of the bot's webhook endpoint (Cloudflare Tunnel recommended for TLS).
# The dashboard POSTs to ${WEBHOOK_URL}/webhook/sync after successful config writes.
WEBHOOK_URL=
# Strong random secret SHARED with the bot (must match the bot's WEBHOOK_SECRET).
# Server-side only — NEVER prefix with NEXT_PUBLIC_ (the secret must not reach the browser).
WEBHOOK_SECRET=
